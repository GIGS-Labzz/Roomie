# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-side only — never expose to browser

# ─── Paystack ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=                # Server-side only — webhook verification

# ─── PWA Push Notifications ──────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                  # Server-side only
VAPID_SUBJECT=mailto:admin@roomie.ng

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.roomie.ng
NEXT_PUBLIC_ADMIN_URL=https://admin.roomie.ng
NEXT_PUBLIC_WEB_URL=https://roomie.ng

# ─── Connection Fee ───────────────────────────────────────────────────────────
CONNECTION_FEE_KOBO=200000          # 200000 kobo = ₦2,000

# ─── Rate Limiting (Phase 10) ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Google OAuth (for Supabase local config) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
